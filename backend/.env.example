# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/arshith-group?retryWrites=true&w=majority

# Port for local Express server (Vercel ignores this and uses its own)
PORT=5000

# Allowed CORS origin(s) - the deployed frontend URL(s), comma-separated
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=development

# Groq API key (get a free key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
